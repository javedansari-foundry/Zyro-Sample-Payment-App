<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/p2p_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:contentDescription="@string/a11y_p2p_toolbar"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/p2p_title" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/p2p_pick_contact" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/p2p_recycler_contacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:contentDescription="@string/a11y_contact_list" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/p2p_instrument" />

    <RadioGroup
        android:id="@+id/p2p_radio_instruments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <RadioButton
            android:id="@+id/p2p_radio_instrument_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/instrument_1" />

        <RadioButton
            android:id="@+id/p2p_radio_instrument_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/instrument_2" />

        <RadioButton
            android:id="@+id/p2p_radio_instrument_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/instrument_3" />

        <RadioButton
            android:id="@+id/p2p_radio_instrument_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/instrument_4" />

        <RadioButton
            android:id="@+id/p2p_radio_instrument_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/instrument_5" />
    </RadioGroup>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/hint_amount">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/p2p_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:hint="@string/hint_note">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/p2p_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences|textMultiLine" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/p2p_btn_send"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/send_money" />
</LinearLayout>
